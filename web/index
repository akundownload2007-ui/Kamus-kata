<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kamus Mini</title>

<style>
:root {
  --bg-gradient: linear-gradient(135deg, #4e73df, #1cc88a);
  --card-bg: white;
  --text-color: #222;
  --input-bg: white;
  --item-bg: #f8f9fc;
  --hover-bg: #4e73df;
  --hover-text: white;
}

body.dark {
  --bg-gradient: linear-gradient(135deg, #1e1e2f, #121212);
  --card-bg: #1f1f2e;
  --text-color: #f1f1f1;
  --input-bg: #2c2c3a;
  --item-bg: #2a2a3a;
  --hover-bg: #6c63ff;
  --hover-text: white;
}

body {
  font-family: Arial, sans-serif;
  background: var(--bg-gradient);
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: center;
  transition: 0.3s;
}

.container {
  background: var(--card-bg);
  color: var(--text-color);
  margin-top: 50px;
  padding: 30px;
  border-radius: 15px;
  width: 90%;
  max-width: 700px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  transition: 0.3s;
}

h1 {
  text-align: center;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-btn {
  cursor: pointer;
  padding: 6px 12px;
  border-radius: 20px;
  border: none;
  background: #4e73df;
  color: white;
  font-size: 12px;
}

input {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #ccc;
  font-size: 16px;
  outline: none;
  margin-top: 15px;
  background: var(--input-bg);
  color: var(--text-color);
}

.result-count {
  margin-top: 10px;
  font-size: 14px;
  opacity: 0.7;
}

ul {
  list-style: none;
  padding: 0;
  margin-top: 15px;
  max-height: 300px;
  overflow-y: auto;
}

li {
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 5px;
  background: var(--item-bg);
  cursor: pointer;
  transition: 0.2s;
}

li:hover {
  background: var(--hover-bg);
  color: var(--hover-text);
  transform: translateX(5px);
}
</style>
</head>

<body>

<div class="container">
  <div class="top-bar">
    <h1>📘 Kamus Skill Issue</h1>
    <button class="toggle-btn" onclick="toggleDark()">🌙 Dark</button>
  </div>

  <input type="text" id="search" placeholder="Ketik kata...">
  <div class="result-count" id="count"></div>
  <ul id="result"></ul>
</div>

<script>
let kamus = [];

Promise.all([
  fetch("kamus1.json").then(res => res.json()),
  fetch("kamus2.json").then(res => res.json())
])
.then(([data1, data2]) => {

  // Gabungkan semua data
  let gabungan = [...data1, ...data2];

  // Ambil kata pertama saja + ubah ke huruf kecil
  gabungan = gabungan.map(kata =>
    kata.split(" ")[0].toLowerCase()
  );

  // Hapus duplikat
  kamus = [...new Set(gabungan)];

  // Urutkan A-Z
  kamus.sort();

})
.catch(error => {
  console.error("Gagal load JSON:", error);
});

const input = document.getElementById("search");
const result = document.getElementById("result");
const count = document.getElementById("count");

input.addEventListener("input", function() {
  const value = input.value.toLowerCase();
  result.innerHTML = "";

  if (value === "") {
    count.textContent = "";
    return;
  }

  const filtered = kamus.filter(kata =>
    kata.startsWith(value)
  );

  count.textContent = filtered.length + " kata ditemukan";

  filtered.forEach(kata => {
    const li = document.createElement("li");
    li.textContent = kata;
    result.appendChild(li);
  });
});

function toggleDark() {
  document.body.classList.toggle("dark");
}
</script>

</body>
</html>
